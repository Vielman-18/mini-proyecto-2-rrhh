generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model empleados {
  id           Int     @id @default(autoincrement())
  nombres      String
  apellidos    String
  dpi          String  @unique
  direccion    String?
  telefono     String?
  salario      Decimal @db.Decimal(10, 2)
  cargo        String?
  departamento String?
  estado       String  @default("activo")
}
