generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model empleados {
  id           Int     @id @default(autoincrement())
  nombres      String
  apellidos    String
  dpi          String  @unique
  direccion    String?
  telefono     String?
  salario      Decimal @db.Decimal(10, 2)
  cargo        String?
  departamento String?
  estado       String  @default("activo")
}

model nomina {
  id             Int       @id @default(autoincrement())
  tipo_periodo   String
  periodo        String
  fecha_inicio   DateTime
  fecha_fin      DateTime
  estado         String    @default("abierta")
  fecha_creacion DateTime? @default(now())
}

model documentos {
  id          Int    @id @default(autoincrement())
  empleado_id Int
  nombre      String
  tipo        String
  fechaCarga  String
  ruta        String
}

model registro_academico {
  id            Int     @id @default(autoincrement())
  empleado_id   Int
  titulo        String
  institucion   String
  fechaGrad     String?
  certificacion String?
}
